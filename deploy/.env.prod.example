# ============================================================
# Eventron — Production .env (放到服务器 /opt/eventron/.env)
# ============================================================

# ── Database (内部网络，无需暴露) ──────────────────────────────
POSTGRES_USER=eventron
POSTGRES_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
POSTGRES_DB=eventron
DATABASE_URL=postgresql+asyncpg://eventron:CHANGE_ME_TO_STRONG_PASSWORD@postgres:5432/eventron

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── LLM Keys ─────────────────────────────────────────────────
LLM_DEFAULT_TIER=smart
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_MODEL=deepseek-chat
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Auth ──────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_TO_RANDOM_SECRET_64CHARS
DEBUG=false
DB_ECHO=false

# ── Plugins ───────────────────────────────────────────────────
PLUGIN_IDENTITY=true
PLUGIN_SEATING=true
PLUGIN_CHECKIN=true
PLUGIN_CHANGE=true
PLUGIN_PAGEGEN=true
PLUGIN_BADGE=true
PLUGIN_GUIDE=true
