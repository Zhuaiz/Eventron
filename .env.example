# ── LLM — multi-provider, per-agent selection ────────────────
LLM_DEFAULT_TIER=smart                        # fast | smart | strong

# Provider: DeepSeek (fast tier) — 最便宜，推荐先配这个
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_MODEL=deepseek-chat

# Provider: OpenAI (smart tier)
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4o-mini

# Provider: Anthropic (strong tier)
ANTHROPIC_API_KEY=sk-ant-xxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Database ─────────────────────────────────────────────────
# 本地 docker compose（默认，make up 即可启动）
DATABASE_URL=postgresql+asyncpg://eventron:eventron@localhost:5432/eventron
# 如果用 Supabase 则改为：
# DATABASE_URL=postgresql+asyncpg://postgres.[ref]:[pwd]@aws-0-[region].pooler.supabase.com:6543/postgres

# Redis — 本地 docker compose 自带
REDIS_URL=redis://localhost:6379/0

# ── WeChat Work ──────────────────────────────────────────────
WECOM_CORP_ID=wwXXXXXXXX
WECOM_BOT_SECRET=xxx
WECOM_BOT_TOKEN=xxx
WECOM_BOT_AES_KEY=xxx

# ── Feature flags ────────────────────────────────────────────
PLUGIN_IDENTITY=true
PLUGIN_SEATING=true
PLUGIN_CHECKIN=true
PLUGIN_CHANGE=true
PLUGIN_PAGEGEN=true
PLUGIN_BADGE=true
PLUGIN_GUIDE=true

# ── Debug ────────────────────────────────────────────────────
DEBUG=true
DB_ECHO=false
